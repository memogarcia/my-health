{
  "name": "me-health-dashboard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.2",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "bun run tauri:dev",
    "build": "bun run tauri:build",
    "preview": "node -e \"console.error('Browser preview is unsupported. Use bun run tauri:dev.'); process.exit(1)\"",
    "vite:dev": "vite",
    "vite:build": "tsc && vite build",
    "tauri": "env PATH=\"$HOME/.cargo/bin:$PATH\" tauri",
    "tauri:dev": "bun run tauri -- dev",
    "tauri:build": "bun run tauri -- build",
    "typecheck": "tsc --noEmit",
    "test": "bun run typecheck && bun run test:js && bun run test:rust",
    "test:js": "tsc -p tsconfig.tests.json && node scripts/run-tests.mjs",
    "test:rust": "node scripts/run-rust-tests.mjs",
    "check": "bun run check:console && bun run check:size && bun run check:i18n-locales && bun run check:i18n && bun run check:rust-format",
    "check:console": "node scripts/check-console.mjs",
    "check:size": "node scripts/check-size.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:i18n-locales": "node scripts/check-i18n-locales.mjs",
    "check:rust-format": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "i18n:baseline": "I18N_WRITE_BASELINE=1 bun run check:i18n",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sonner": "^2.0.7",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "typescript": "~6.0.3",
    "vite": "^8.1.3"
  }
}
